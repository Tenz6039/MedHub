<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.medhub.mapper.CouponMapper">
    
    <!-- 结果映射 -->
    <resultMap id="CouponResultMap" type="com.medhub.entity.Coupon">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="type" property="type"/>
        <result column="min_amount" property="minAmount"/>
        <result column="discount_value" property="discountValue"/>
        <result column="max_discount_amount" property="maxDiscountAmount"/>
        <result column="description" property="description"/>
        <result column="total_count" property="totalCount"/>
        <result column="issued_count" property="issuedCount"/>
        <result column="user_limit" property="userLimit"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="create_user" property="createUser"/>
        <result column="update_user" property="updateUser"/>
    </resultMap>

    <!-- 新增优惠券 -->
    <insert id="insert" parameterType="com.medhub.entity.Coupon" useGeneratedKeys="true" keyProperty="id">
        insert into coupon (
            name, 
            type, 
            min_amount, 
            discount_value, 
            max_discount_amount, 
            description, 
            total_count, 
            issued_count, 
            user_limit, 
            start_time, 
            end_time, 
            status, 
            create_time, 
            update_time,
            create_user
        ) values (
            #{name}, 
            #{type}, 
            #{minAmount}, 
            #{discountValue}, 
            #{maxDiscountAmount}, 
            #{description}, 
            #{totalCount}, 
            #{issuedCount}, 
            #{userLimit}, 
            #{startTime}, 
            #{endTime}, 
            #{status}, 
            #{createTime}, 
            #{updateTime},
            #{createUser}
        )
    </insert>

    <!-- 更新优惠券 -->
    <update id="update" parameterType="com.medhub.entity.Coupon">
        update coupon
        <set>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="description != null">
                description = #{description},
            </if>
            <if test="totalCount != null">
                total_count = #{totalCount},
            </if>
            <if test="userLimit != null">
                user_limit = #{userLimit},
            </if>
            <if test="startTime != null">
                start_time = #{startTime},
            </if>
            <if test="endTime != null">
                end_time = #{endTime},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="updateUser != null">
                update_user = #{updateUser},
            </if>
            update_time = now()
        </set>
        where id = #{id}
    </update>

    <!-- 根据 ID 删除优惠券（物理删除） -->
    <delete id="deleteById" parameterType="java.lang.Long">
        delete from coupon where id = #{id}
    </delete>

    <!-- 根据 ID 查询优惠券 -->
    <select id="getById" parameterType="java.lang.Long" resultMap="CouponResultMap">
        select * from coupon where id = #{id}
    </select>

    <!-- 分页查询优惠券 -->
    <select id="pageQuery" parameterType="com.medhub.dto.CouponPageQueryDTO" resultMap="CouponResultMap">
        select * from coupon
        <where>
            <if test="name != null and name != ''">
                and name like concat('%', #{name}, '%')
            </if>
            <if test="type != null">
                and type = #{type}
            </if>
            <if test="status != null">
                and status = #{status}
            </if>
            <if test="beginTime != null">
                and start_time &gt;= #{beginTime}
            </if>
            <if test="endTime != null">
                and end_time &lt;= #{endTime}
            </if>
        </where>
        order by create_time desc
    </select>

    <!-- 查询优惠券总数 -->
    <select id="count" parameterType="com.medhub.dto.CouponPageQueryDTO" resultType="java.lang.Long">
        select count(*) from coupon
        <where>
            <if test="name != null and name != ''">
                and name like concat('%', #{name}, '%')
            </if>
            <if test="type != null">
                and type = #{type}
            </if>
            <if test="status != null">
                and status = #{status}
            </if>
            <if test="beginTime != null">
                and start_time &gt;= #{beginTime}
            </if>
            <if test="endTime != null">
                and end_time &lt;= #{endTime}
            </if>
        </where>
    </select>

    <!-- 查询优惠券统计信息 -->
    <select id="getStatistics" resultMap="CouponResultMap">
        select 
            count(*) as total_count,
            sum(case when status = 1 then 1 else 0 end) as active_count,
            sum(case when status = 0 then 1 else 0 end) as disabled_count,
            sum(issued_count) as total_issued,
            sum(discount_value) as total_discount
        from coupon
    </select>

    <!-- 分页查询可领取的优惠券 -->
    <select id="pageQueryAvailable" parameterType="com.medhub.dto.CouponPageQueryDTO" resultMap="CouponResultMap">
        select * from coupon
        <where>
            and status = 1
            and start_time &lt;= now()
            and end_time &gt; now()
            and (total_count = -1 or (IFNULL(issued_count, 0) &lt; total_count))
            <if test="name != null and name != ''">
                and name like concat('%', #{name}, '%')
            </if>
            <if test="type != null">
                and type = #{type}
            </if>
        </where>
        order by create_time desc
    </select>

    <!-- 更新已领取数量（自增） -->
    <update id="updateIssuedCount">
        update coupon 
        set issued_count = IFNULL(issued_count, 0) + 1, update_time = now() 
        where id = #{id}
    </update>
</mapper>
