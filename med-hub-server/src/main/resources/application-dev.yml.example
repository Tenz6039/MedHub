# ============================================
# MedHub 智慧购药平台 - 开发环境配置示例
# ============================================
# 使用说明：
# 1. 复制此文件并重命名为 application-dev.yml
# 2. 根据实际情况修改下面的配置值
# 3. 注意：application-dev.yml 包含敏感信息，不应提交到 Git
# ============================================

med-hub:
  # ============================================
  # 数据库配置
  # ============================================
  datasource:
    # MySQL 驱动类名（一般不需要修改）
    driver-class-name: com.mysql.cj.jdbc.Driver
    
    # 数据库连接地址
    host: localhost
    
    # 数据库端口号
    port: 3306
    
    # 数据库名称
    database: med_hub
    
    # 数据库用户名（请修改为您的实际用户名）
    username: your_database_username
    
    # 数据库密码（请修改为您的实际密码）
    password: your_database_password

  # ============================================
  # 阿里云 OSS 对象存储配置
  # ============================================
  alioss:
    # OSS  endpoint（请根据您的区域修改）
    # 常见 endpoint:
    # - oss-cn-hangzhou.aliyuncs.com (华东 1-杭州)
    # - oss-cn-shanghai.aliyuncs.com (华东 2-上海)
    # - oss-cn-wuhan-lr.aliyuncs.com (华中 1-武汉)
    # - oss-cn-beijing.aliyuncs.com (华北 2-北京)
    endpoint: oss-cn-your-region.aliyuncs.com
    
    # AccessKey ID（请在阿里云控制台获取）
    access-key-id: your_access_key_id
    
    # AccessKey Secret（请在阿里云控制台获取，注意保密）
    access-key-secret: your_access_key_secret
    
    # OSS Bucket 名称（需要全局唯一）
    bucket-name: your-bucket-name

  # ============================================
  # Redis 配置
  # ============================================
  redis:
    # Redis 服务器地址
    host: localhost
    
    # Redis 端口号
    port: 6379
    
    # Redis 密码（如果没有设置密码，留空即可）
    password:
    
    # Redis 数据库索引（默认使用 0 号库）
    database: 0

  # ============================================
  # 微信支付配置
  # ============================================
  wechat:
    # 微信公众号/小程序 AppID
    # 在微信公众平台 (https://mp.weixin.qq.com) 获取
    appid: your_wechat_appid
    
    # 微信公众号/小程序 AppSecret
    # 注意保密，不要泄露
    secret: your_wechat_secret

# ============================================
# 配置完成
# ============================================
# 如有问题，请检查：
# 1. 数据库连接是否正常
# 2. Redis 服务是否启动
# 3. 阿里云 OSS 配置是否正确
# 4. 微信 AppID 和 Secret 是否有效
# ============================================
